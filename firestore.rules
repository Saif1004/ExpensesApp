rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════
    // DEFAULT DENY
    // Every collection is locked unless explicitly opened below.
    // This is the most important line — it prevents accidental exposure
    // if a new collection is added without a corresponding rule.
    // ══════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }

    // ── HELPER FUNCTIONS ─────────────────────────────────────────────

    // Must be authenticated with a verified email
    function verified() {
      return request.auth != null
          && request.auth.token.email_verified == true;
    }

    // True if the calling user is the registered owner of the given org.
    // Uses one cross-document get() per unique orgId per request.
    // Firebase caches the result so multiple docs in the same org only
    // trigger ONE extra read (not one per document).
    function isOrgOwner(orgId) {
      return get(/databases/$(database)/documents/organisations/$(orgId))
               .data.ownerId == request.auth.uid;
    }

    // True if the calling user is an admin of the given org — either the
    // original owner OR a member explicitly promoted via the orgAdmins array.
    // The orgAdmins array is maintained client-side by manage-employees and
    // can only be written by the org owner (enforced by the organisations rule).
    function isOrgAdmin(orgId) {
      // .get('orgAdmins', []) returns [] when the field is absent, avoiding
      // the 'key in map' operator which can be unreliable on missing fields.
      return get(/databases/$(database)/documents/organisations/$(orgId)).data.ownerId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/organisations/$(orgId)).data.get('orgAdmins', []);
    }

    // ══════════════════════════════════════════════════════════════════
    // COLLECTION: users/{uid}
    //
    // Each user may only read and write their OWN document.
    //
    // Protected fields that only Azure Functions (Admin SDK) may write:
    //   plan, stripeCustomerId, stripePaymentMethodId, stripeAccountId,
    //   stripeOnboardingComplete, stripe* payout fields, lastAiCall,
    //   rateLimit* fields.
    //
    // An attacker cannot self-upgrade their plan or inject Stripe data.
    // ══════════════════════════════════════════════════════════════════

    match /users/{uid} {

      // Owner-only read — NOT public
      allow read: if verified() && request.auth.uid == uid;

      // Create own profile during sign-up.
      // Uses request.auth != null (not verified()) because email is not yet
      // verified at the moment the batch write runs — verification email is
      // sent immediately after, then the user is signed out.
      // Minimal rule: any authenticated user can create their own profile doc.
      // The path wildcard {uid} already ensures the document ID == auth UID.
      allow create: if request.auth != null
                    && request.auth.uid == uid;

      // Update own profile — cannot touch sensitive server-managed fields
      allow update: if verified()
                    && request.auth.uid == uid
                    && !request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasAny([
                          'uid',
                          'email',
                          'plan',
                          'stripeCustomerId',
                          'stripePaymentMethodId',
                          'stripeCardLast4',
                          'stripeCardBrand',
                          'stripeAccountId',
                          'stripeOnboardingComplete',
                          'stripePayoutLast4',
                          'stripePayoutBrand',
                          'stripePayoutType',
                          'lastAiCall',
                          'rateLimitOCR',
                          'rateLimitUpload',
                          'rateLimitValidate',
                          'rateLimitChatbot',
                          'rateLimitAnalytics',
                          'rateLimitDeleteAccount',
                          'rateLimitSetupPayment',
                          'rateLimitCreateAccount',
                          'rateLimitOnboardingLink'
                        ]);

      // Deletion is handled exclusively by the deleteAccount Azure Function
      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    // COLLECTION: usernames/{username}
    //
    // Username → UID + email lookup table used during sign-in.
    //
    // READ: PUBLIC — must be unauthenticated because the sign-in flow
    //   resolves a username to an email BEFORE the user has authenticated.
    //   The document only stores { uid, email } — no more sensitive than
    //   a public profile. Security still depends on Firestore rules for
    //   all other collections.
    //
    // CREATE: only the account owner during sign-up. The user IS
    //   authenticated at this point (just not email-verified yet).
    //
    // UPDATE/DELETE: locked — Admin SDK only.
    // ══════════════════════════════════════════════════════════════════

    match /usernames/{username} {

      // Public read — needed for pre-auth username → email lookup
      allow read: if true;

      // UID must match — that's sufficient to prove ownership
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      allow update: if false;  // usernames are permanent once claimed
      allow delete: if false;  // deleteAccount Azure Function only
    }

    // ══════════════════════════════════════════════════════════════════
    // COLLECTION: config/{document}
    //
    // Server-managed feature flags (e.g. AI kill switch at config/ai).
    // Verified users may READ so the app can react to feature toggles.
    // WRITE is blocked from all clients — Azure Functions (Admin SDK) only.
    // ══════════════════════════════════════════════════════════════════

    match /config/{document} {
      allow read:  if verified();
      allow write: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    // COLLECTION: memberships/{membershipId}
    //
    // Links a user to an org with a role (admin | employee) and
    // status (pending | approved).
    //
    // Read:   owner of the record OR the org owner (for admin panel)
    // Create: (a) employee joining via invite → role=employee, status=pending
    //         (b) admin self-joining their own new org → role=admin, status=approved
    // Update: ONLY the org owner may change status / role.
    //         userId and orgId are immutable once set.
    // Delete: blocked from client (deleteAccount Azure Function only)
    // ══════════════════════════════════════════════════════════════════

    match /memberships/{membershipId} {

      allow read: if verified() && (
        // Employee reads their own membership
        resource.data.userId == request.auth.uid
        // Any org admin reads all memberships in their org (admin panel)
        || isOrgAdmin(resource.data.orgId)
      );

      // (a) Employee joins via invite code (email not yet verified at sign-up)
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.role   == 'employee'
                    && request.resource.data.status == 'pending';

      // (b) Admin self-joining their new org during sign-up (email not yet verified)
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.role   == 'admin'
                    && request.resource.data.status == 'approved';

      // Any org admin may approve/reject/change role.
      // Core identity fields (userId, orgId) are locked after creation.
      allow update: if verified()
                    && isOrgAdmin(resource.data.orgId)
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.orgId  == resource.data.orgId;

      // Org owner can remove members (delete membership doc)
      allow delete: if verified() && isOrgOwner(resource.data.orgId);
    }

    // ══════════════════════════════════════════════════════════════════
    // COLLECTION: organisations/{orgId}
    //
    // Read:   any verified user (AuthProvider loads the org for all
    //         members; org data contains no PII).
    // Create: only the declared owner, during sign-up.
    //         Must start on the "free" plan — plan upgrades are done
    //         via RevenueCat / Azure Function, never client writes.
    // Update: only the org owner.
    //         Billing and AI credit fields are server-managed only.
    // Delete: blocked (deleteAccount Azure Function only).
    // ══════════════════════════════════════════════════════════════════

    match /organisations/{orgId} {

      // request.auth != null (not verified()) so new members can look up
      // the org by invite code during sign-up before email is verified.
      allow read: if request.auth != null;

      // request.auth != null (not verified()) — email not yet verified at sign-up time
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.plan    == 'free';

      // Org owner: full update except server-managed billing fields.
      allow update: if verified()
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId
                    && !request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasAny([
                          'plan',
                          'ownerId',
                          'aiCreditsRemaining',
                          'aiCreditsResetAt',
                          'aiUsage'
                        ]);

      // Any org admin (owner OR promoted): may update only safe fields
      // (categories, inviteCode, orgAdmins). Billing and identity locked.
      allow update: if verified()
                    && isOrgAdmin(orgId)
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['categories', 'inviteCode', 'orgAdmins']);

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    // COLLECTION: claims/{claimId}
    //
    // Claims are CREATED by the validateClaim Azure Function (Admin SDK).
    // The client is not permitted to create claims directly.
    //
    // Read:   employee reads their own claims;
    //         org owner reads all claims in their org (admin panel).
    //
    // Update: org owner may update status, adminFeedback, and
    //         rejectedAt (reject without payment); all financial and
    //         identity fields are immutable from the client.
    //
    // Delete: not permitted from client.
    // ══════════════════════════════════════════════════════════════════

    match /claims/{claimId} {

      allow read: if verified() && (
        resource.data.userId == request.auth.uid
        || isOrgAdmin(resource.data.orgId)
      );

      // All claim creation goes through the validateClaim Azure Function
      allow create: if false;

      // Any org admin can approve/reject a claim (update status + feedback).
      // An admin CANNOT approve their own claim — this prevents self-approval fraud.
      // Financial and identity fields are completely locked.
      allow update: if verified()
                    && isOrgAdmin(resource.data.orgId)
                    // Self-approval prevention: admin cannot action their own claim
                    && resource.data.userId != request.auth.uid
                    // Lock all financial and identity fields
                    && request.resource.data.userId       == resource.data.userId
                    && request.resource.data.orgId        == resource.data.orgId
                    && request.resource.data.amount       == resource.data.amount
                    && request.resource.data.category     == resource.data.category
                    && request.resource.data.merchant     == resource.data.merchant
                    && request.resource.data.purchaseDate == resource.data.purchaseDate
                    && request.resource.data.receiptUrl   == resource.data.receiptUrl
                    // Only these fields may change:
                    // status, adminFeedback, rejectedAt, approvedAt, approvedBy
                    && request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly([
                          'status',
                          'statusUpdatedAt',
                          'adminFeedback',
                          'rejectedAt',
                          'approvedAt',
                          'approvedBy',
                          'adminId'
                        ]);

      allow delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════
    // COLLECTION: policies/{policyId}
    //
    // Policies are created by the parsePolicy Azure Function (Admin SDK).
    //
    // Read:   any verified user (needed during claim submission to load
    //         org spending limits and receipt thresholds).
    // Create: Admin SDK only (parsePolicy Azure Function).
    // Update: Admin SDK only.
    // Delete: org owner only (so admins can remove outdated policies).
    // ══════════════════════════════════════════════════════════════════

    match /policies/{policyId} {
      allow read:   if verified();
      allow create: if false;   // parsePolicy Azure Function only
      allow update: if false;   // Azure Function only
      allow delete: if verified() && isOrgAdmin(resource.data.orgId);
    }

  }
}
